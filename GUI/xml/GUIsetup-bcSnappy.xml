<?xml version="1.0"?>
<setupData>
	<XMLFileDescription filename="CFD_input.xml" appname="bcSnappy">
		<GEO type="frame">
		    <CAD type="CAD" probePoint="true">step</CAD>
		</GEO>

		<MESH type="frame">
			<coarseMesh type="float">0.25</coarseMesh>
			<scale type="float">1.0</scale>
                        <splitMesh type="dropdown">largest<option type="string">largest</option>
                                                          <option type="string">true</option>
                                                          <option type="string">false</option>
                        </splitMesh>
	                <patch    type="multiple" specifyName="CADgroups">
                            <type type="dropdown">wall<option type="string">wall</option>
                                                      <option type="string">patch</option>
                                                      <option type="string">symmetry</option>
                            </type>
	                    <refLevel       type="int">0</refLevel>
	                    <refOnCorners   type="int">2</refOnCorners>
	                    <nSurfaceLayers type="int">0</nSurfaceLayers>
	                    <expansionRatio type="float">1.2</expansionRatio>
                	</patch>
	                <baffle   type="multiple" specifyName="CADgroups">
                            <type type="dropdown">wall<option type="string">wall</option></type>
	                    <refLevel       type="int">0</refLevel>
	                    <refOnCorners   type="int">2</refOnCorners>
	                    <nSurfaceLayers type="int">0</nSurfaceLayers>
	                    <expansionRatio type="float">1.2</expansionRatio>
                	</baffle>
	                <cellZone type="multiple" specifyName="CADgroups">
	                    <refLevel        type="int">0</refLevel>
	                    <refOnCorners    type="int">2</refOnCorners>
                            <NonConformalCouples type="dropdown">false<option type="string">true</option>
                                                                      <option type="string">false</option>
                            </NonConformalCouples>
			    <boundingPatches type="string">impeller</boundingPatches>
                	</cellZone>
	                <faceZone type="multiple" specifyName="CADgroups">
                	</faceZone>
	                <refinement type="multiple" specifyName="CADgroups">
	                    <refLevel     type="int">0</refLevel>
                	</refinement>
	                <extrusion type="multiple" specifyName="CADgroups">
	                    <directionX type="float">0</directionX>
	                    <directionY type="float">0</directionY>
	                    <directionZ type="float">1.0</directionZ>
	                    <thickness  type="float">1.0</thickness>
	                    <expansionRatio type="float">1.1</expansionRatio>
                	</extrusion>
                        <script type="dropdown">snappyHexMesh-of14<option type="string">snappyHexMesh-of14</option>
                                                                  <option type="string">snappyHexMesh-of13</option>
                                                                  <option type="string">snappyHexMesh-of12</option>
                        </script>
		</MESH>
	</XMLFileDescription>
        <cloudExecution>
  	      <script>cloudHPC-CFDtemplate</script>
	      <ram>highmem</ram>
              <nopre>0</nopre>
	      <download>OPENFOAM-constant.tar.gz</download>
	      <download>OPENFOAM-system.tar.gz</download>
        </cloudExecution>
</setupData>
